{
  "manifest_version": 3,
  "name": "Procrastop - Focus & Bloqueur de site",
  "version": "1.0",
  "description": "Bloque les distractions en temps réel en synchronisation avec l'application Procrastop.",
  "permissions": [
    "declarativeNetRequest",
    "storage",
    "alarms"
  ],
  "host_permissions": [
    "<all_urls>"
  ],
  "background": {
    "service_worker": "background.js"
  },
  "action": {
    "default_popup": "popup.html",
    "default_title": "Procrastop"
  },
  "web_accessible_resources": [
    {
      "resources": [
        "blocked.html",
        "blocked.js"
      ],
      "matches": [
        "<all_urls>"
      ]
    }
  ]
}
